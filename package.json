{
  "name": "packedplaces",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:seed": "tsx --tsconfig tsconfig.scripts.json src/lib/db/seed.ts",
    "db:ingest-holidays": "tsx --tsconfig tsconfig.scripts.json scripts/ingest-holidays.ts",
    "db:precompute": "tsx --tsconfig tsconfig.scripts.json scripts/precompute-heatmap.ts",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:ingest-holidays && npm run db:precompute",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:boundaries": "tsx --tsconfig tsconfig.scripts.json scripts/build-region-boundaries.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "@next/third-parties": "^16.1.6",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.26.8",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "maplibre-gl": "^5.19.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "pg": "^8.19.0",
    "rc-slider": "^11.1.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-map-gl": "^8.1.0",
    "resend": "^6.9.3",
    "swr": "^2.4.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@turf/helpers": "^7.3.4",
    "@turf/simplify": "^7.3.4",
    "@turf/truncate": "^7.3.4",
    "@turf/union": "^7.3.4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
